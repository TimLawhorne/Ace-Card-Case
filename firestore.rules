rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // DIAGNOSTIC RULES: Allow all authenticated access to their own data
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    match /inventory/{itemId} {
      allow read, write: if request.auth != null && (resource == null || resource.data.ownerId == request.auth.uid || request.resource.data.ownerId == request.auth.uid);
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
